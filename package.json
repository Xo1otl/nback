{
  "name": "nback",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun src/index.html",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "NODE_ENV=production bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --env='BUN_PUBLIC_*' && cp -r public/. dist/ && bun scripts/gen-sw.ts",
    "preview": "bun scripts/preview.ts"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^6.0.3"
  }
}
